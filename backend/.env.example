# ============================================
# AI Interview Analysis API - Environment Vars
# ============================================
# Copy this file to .env and fill in your values

# App
APP_NAME="AI Interview Analysis API"
APP_VERSION="1.0.0"
DEBUG=true
LOG_LEVEL=INFO

# Database - PostgreSQL connection string
# For local PostgreSQL:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interview
# For Supabase PostgreSQL (use connection string from Supabase dashboard):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Supabase (optional, for Supabase-specific features)
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback/google
